# Artefactos de compilación (el más pesado)
target/

# Modelos de IA — demasiado grandes para el contexto de build
plugins/provider-ai/models/
plugins/provider-ai/target/

# Entornos virtuales Python
venv/
.venv/

# Frontends (no se necesitan en el backend): excluirlos COMPLETOS evita que un
# cambio de UI invalide la capa COPY del backend y dispare un rebuild de cargo
# de ~8 min en cada deploy. El frontend tiene su propio contexto de build.
tidol-frontend/
tidol-tv-lite/
tidol-tv-lite-backup/

# Datos de usuario y almacenamiento local
storage/
tidol-core/covers/
tidol-core/storage/

# Archivos de desarrollo
*.py
*.sh
bad_engine/
test_yt/
scratch/

# Git
.git/
.gitignore

# Cookies (montado por volumen, no necesario en build)
*cookies*.txt

# Logs y temporales
*.log
tmp/
