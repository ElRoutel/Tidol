  "query": "\n                SELECT t.mbid, t.title, t.artist, t.cover_url\n                FROM play_history p\n                JOIN track_links t ON p.track_mbid = t.mbid\n                WHERE p.user_id = ?\n                GROUP BY t.mbid, t.title, t.artist, t.cover_url\n                ORDER BY MAX(p.played_at) DESC\n                LIMIT 10\n                ",
