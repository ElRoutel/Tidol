  "query": "\n            SELECT p.track_mbid AS track_id, p.played_at, t.title, t.artist, t.cover_url\n            FROM play_history p\n            JOIN track_links t ON t.mbid = p.track_mbid\n            WHERE p.user_id = ?\n            ORDER BY p.played_at DESC\n            LIMIT 50\n            ",
