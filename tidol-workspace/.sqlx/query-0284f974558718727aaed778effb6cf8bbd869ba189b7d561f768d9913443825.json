{
  "db_name": "MySQL",
  "query": "\n                SELECT a.mbid, a.name, a.cover_url\n                FROM play_history p\n                JOIN track_links t ON p.track_mbid = t.mbid\n                JOIN artists a ON t.artist = a.name\n                WHERE p.user_id = ?\n                GROUP BY a.mbid, a.name, a.cover_url\n                ORDER BY COUNT(p.id) DESC\n                LIMIT 6\n                ",
