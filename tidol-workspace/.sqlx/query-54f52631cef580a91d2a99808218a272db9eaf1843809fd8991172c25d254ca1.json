{
  "db_name": "MySQL",
  "query": "\n            SELECT a.mbid as id, a.title, a.artist_mbid as artist_id, ar.name as artist_name, a.release_year, a.cover_url, a.cover_status\n            FROM albums a\n            LEFT JOIN artists ar ON a.artist_mbid = ar.mbid\n            ORDER BY a.release_year DESC\n            LIMIT 50\n            ",
