  "query": "\n                SELECT t.artist, t.title\n                FROM play_history p\n                JOIN track_links t ON p.track_mbid = t.mbid\n                WHERE p.user_id = ?\n                GROUP BY t.artist, t.title\n                ORDER BY COUNT(p.id) DESC\n                LIMIT 1\n                ",
